PORT=3000
CORS_ORIGIN=https://your-domain.com
FRONTEND_URL=https://your-domain.com/donate
API_PUBLIC_URL=https://your-api-domain.com
DEFAULT_SITE_ID=main
DEFAULT_SITE_NAME=Main Site
DONATION_MIN_AMOUNT=1000
QRISPW_API_KEY=your_qrispw_api_key
QRISPW_API_SECRET=your_qrispw_api_secret
QRISPW_WEBHOOK_SECRET=your_qrispw_webhook_secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: pakai ini kalau satu backend menerima donasi dari banyak situs.
# Request frontend bisa mengirim body/header/query `site_id`, atau backend akan
# mencoba mengenali situs dari Origin/Referer.
# DONATION_SITES_JSON='[
#   {
#     "id": "site-a",
#     "name": "Site A",
#     "origins": ["https://site-a.com"],
#     "frontend_url": "https://site-a.com/donate",
#     "min_amount": 1000,
#     "qris_api_key": "optional_site_specific_key",
#     "qris_api_secret": "optional_site_specific_secret",
#     "qris_webhook_secret": "optional_site_specific_webhook_secret"
#   },
#   {
#     "id": "site-b",
#     "name": "Site B",
#     "origins": ["https://site-b.com"],
#     "frontend_url": "https://site-b.com/donate",
#     "min_amount": 5000
#   }
# ]'
